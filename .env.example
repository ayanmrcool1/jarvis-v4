# Required for the AI brain, voice responses, vision tools, and web research.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Runtime user profile / personalisation
# Defaults to the operating system username if left blank.
JARVIS_USER_ID=
JARVIS_USER_NAME=

# Voice activation
JARVIS_HOTKEY=ctrl+space
JARVIS_KEYBIND_SILENCE_SECONDS=5.0
JARVIS_KEYBIND_SPEECH_START_TIMEOUT_SECONDS=5.0
JARVIS_WAKE_SPEECH_START_TIMEOUT_SECONDS=6.0
JARVIS_FOLLOWUP_SPEECH_START_TIMEOUT_SECONDS=8.0
JARVIS_WAKE_SESSION_MAX_TURNS=8
JARVIS_RECORDING_PRE_ROLL_SECONDS=1.5
JARVIS_WHISPER_SPEECH_PAD_MS=350

# Web HUD debugging
# Routine successful HTTP access logs are quiet by default.
# Set either option to true when you need to inspect every HUD request.
JARVIS_WEB_HUD_ACCESS_LOGS=false
WEB_HUD_VERBOSE_HTTP=false

# TTS provider.
# edge works out of the box and does not need an API key.
# Set TTS_PROVIDER=elevenlabs only if you want ElevenLabs voice output.
TTS_PROVIDER=edge
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=zDSojkKhhVNCWoYn9KW7
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_MAX_CHARS=800
ELEVENLABS_TIMEOUT_SECONDS=8
ELEVENLABS_CACHE_ENABLED=true
ELEVENLABS_CACHE_MAX_MB=500
ELEVENLABS_CACHE_MAX_AGE_DAYS=30

# Optional ElevenLabs voice settings. Leave blank to use ElevenLabs defaults.
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY_BOOST=
ELEVENLABS_STYLE=
ELEVENLABS_USE_SPEAKER_BOOST=
